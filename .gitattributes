# Set default line ending behavior
* text=auto

# PowerShell scripts should use CRLF on Windows
*.ps1 text eol=crlf

# Shell scripts should use LF
*.sh text eol=lf

# Ensure these files always use LF
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.md text eol=lf

