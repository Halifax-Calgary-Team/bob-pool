{
  "name": "bob-pool-frontend",
  "version": "1.0.0",
  "type": "module",
  "description": "Bob Pool - IBM Carpooling Frontend",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:log": "vitest --reporter=verbose --reporter=json --outputFile=test-results.json 2>&1 | tee test-results.log",
    "test:coverage:log": "vitest --coverage --reporter=verbose 2>&1 | tee test-coverage.log"
  },
  "dependencies": {
    "@carbon/react": "^1.108.0",
    "@carbon/styles": "^1.107.0",
    "leaflet": "^1.9.4",
    "leaflet-routing-machine": "^3.2.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^1.0.4",
    "jsdom": "^23.0.1",
    "vite": "^6.4.2",
    "vitest": "^1.0.4",
    "@vitest/coverage-v8": "^1.0.4"
  }
}
