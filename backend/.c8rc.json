{
  "all": true,
  "include": [
    "routes/**/*.js",
    "helpers/**/*.js",
    "middleware/**/*.js"
  ],
  "exclude": [
    "test/**",
    "node_modules/**",
    "**/*.test.js",
    "db.js",
    "server.js",
    "migrate.js"
  ],
  "reporter": [
    "text",
    "text-summary",
    "html",
    "lcov",
    "json"
  ],
  "report-dir": "./coverage",
  "temp-directory": "./coverage/tmp",
  "check-coverage": false,
  "lines": 80,
  "functions": 80,
  "branches": 80,
  "statements": 80
}