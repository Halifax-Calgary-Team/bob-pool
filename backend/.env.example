# Database Configuration
# PostgreSQL connection details
DB_HOST=db
DB_USER=bobpool
DB_PASSWORD=bobpool_dev
DB_NAME=bobpool
DB_PORT=5432

# Session Configuration
# Secret key for session encryption - CHANGE THIS IN PRODUCTION!
SESSION_SECRET=your-secret-key-here

# Server Configuration
# Port for the Express server
PORT=3001

# Environment
# Set to 'production' in production environment
NODE_ENV=development

# IBM App ID Configuration
# IBM App ID credentials for SSO authentication
# Get these from IBM Cloud App ID service dashboard
APPID_TENANT_ID=
APPID_CLIENT_ID=
APPID_SECRET=
APPID_OAUTH_SERVER_URL=https://ca-tor.appid.cloud.ibm.com/oauth/v4/d1844e9f-8bf3-447e-a70c-9dc22990c462


ENV_TEST="from .env"
PORT=3001
HOSTNAME="localhost"
HOST_URL="http://localhost:3001"
SERV_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"
SESSION_SECRET="abc12345"
STRAT_TENANT_ID=""
STRAT_CLIENT_ID=""
STRAT_SECRET=""
STRAT_NAME="bob-pool"
STRAT_OAUTH_URL="https://ca-tor.appid.cloud.ibm.com/oauth/v4/${STRAT_TENANT_ID}"
STRAT_PROFILE_URL="https://ca-tor.appid.cloud.ibm.com"
STRAT_DISCOVERY_EP="https://ca-tor.appid.cloud.ibm.com/oauth/v4/${STRAT_TENANT_ID}/.well-known/openid-configuration"
STRAT_TYPE="regularwebapp"
STRAT_REDIRECT_CB="${HOST_URL}/callback"

SASS_PATH="node_modules"
